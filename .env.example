# Demonstration-only local values. Copy to .env and replace before sharing the environment.
POSTGRES_DB=motion
POSTGRES_USER=motion
POSTGRES_PASSWORD=motion-local-demo-change-me
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-local-demo-change-me

# Host addresses. Keep these coordinated with the Keycloak realm import.
FRONTEND_HOST_PORT=4200
BACKEND_HOST_PORT=8080
KEYCLOAK_HOST_PORT=8180
POSTGRES_HOST_PORT=5432
