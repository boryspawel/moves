{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "api:snapshot": "cd .. && mvn -q -Dtest=OpenApiSnapshotIntegrationTest -Dopenapi.snapshot=web/openapi/openapi.json test",
    "api:generate": "openapi-generator-cli generate -i openapi/openapi.json -g typescript-fetch -o src/app/api/generated --additional-properties=npmName=@moves/api-client,npmVersion=1.0.0 && node scripts/patch-openapi-client.mjs",
    "api:format": "prettier --write src/app/api/generated",
    "api:refresh": "npm run api:snapshot && npm run api:generate && npm run api:format",
    "api:verify": "npm run api:refresh && git diff --exit-code -- openapi/openapi.json src/app/api/generated"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/cdk": "22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/animations": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "22.0.5",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "keycloak-js": "26.2.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "4.12.1",
    "@openapitools/openapi-generator-cli": "2.40.0",
    "@playwright/test": "1.61.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "6.0.3",
    "vitest": "^4.0.8"
  }
}
